{
  "manifest_version": 3,
  "name": "书签白板",
  "description": "快速整理你的网络资源 | 隐私优先的本地书签管理工具",
  "version": "3.2.1",
  "chrome_url_overrides": {
    "newtab": "new-tab.html"
  },
  "permissions": [
    "storage",
    "contextMenus",
    "tabs",
    "scripting",
    "sidePanel",
    "activeTab"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "js/background.js"
  },
  "side_panel": {
    "default_path": "sidebar.html"
  },
  "action": {
    "default_title": "书签白板"
  },
  "icons": {
    "16": "icons/logo.png",
    "48": "icons/logo.png",
    "128": "icons/logo.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
